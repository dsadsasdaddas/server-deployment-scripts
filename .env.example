# 服务器配置 | Server Configuration
SERVER_IP=YOUR_SERVER_IP
SERVER_USER=root
# SERVER_USER=ubuntu  # 对于Ubuntu系统

# SSH配置 | SSH Configuration
SSH_KEY_PATH=~/.ssh/id_rsa_deploy
SSH_PORT=22

# 部署目录 | Deployment Directories
WANGYUE_DEPLOY_DIR=/var/www/wangyue-website
ARCHIVE_VAULT_DEPLOY_DIR=/var/www/archive-vault

# 数据库配置 | Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wangyue_db
DB_USER=wangyue_user
DB_PASSWORD=YOUR_SECURE_PASSWORD

# GitHub配置 | GitHub Configuration
GITHUB_REPO=https://github.com/YOUR_USERNAME/wangyue-website.git
GITHUB_TOKEN=your_github_token_here

# 域名配置（可选）| Domain Configuration (Optional)
DOMAIN=wangyue-website.com
ARCHIVE_DOMAIN=archive.example.com

# 部署选项 | Deployment Options
ENABLE_SSL=false
ENABLE_BACKUP=true
ENABLE_MONITORING=true

# 通知配置（可选）| Notification Configuration (Optional)
NOTIFY_EMAIL=your-email@example.com
NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR_WEBHOOK

# Docker配置 | Docker Configuration
DOCKER_REGISTRY=docker.io
DOCKER_NAMESPACE=your-username
DOCKER_TAG=latest